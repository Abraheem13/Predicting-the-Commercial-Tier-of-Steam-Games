.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/

# Data - do not commit the raw CSV (too large, redistribute separately)
data/raw/*.csv
data/raw/*.json
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Figures are regenerated by the scripts
reports/figures/*
!reports/figures/.gitkeep

.DS_Store
